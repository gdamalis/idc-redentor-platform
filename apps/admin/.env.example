ENVIRONMENT_NAME=local

# --- MongoDB (Ministry Admin Panel — congregant PII) ---

# Connection string for the shared Atlas cluster. The DB name rides in the URI
# PATH (never a separate ADMIN_DB_NAME env var — that variable is cancelled).
# Required shape: authSource=admin explicit, maxPoolSize set to match this
# app's MongoClient options (10), e.g.:
#   mongodb+srv://<host>/ministry-admin?authSource=admin&retryWrites=true&w=majority&maxPoolSize=10
# Use "ministry-admin-staging" for the staging tier. Never point this at a
# "website"/"website-staging" DB (apps/web owns those) or a reserved Mongo
# system DB (test/admin/local/config) — getAdminDb() fails closed on those.
# Do not commit a real connection string here (server-side only, gitignored).
MONGODB_URI=

# --- Base URL ---

# Canonical base URL this admin app is hosted on. Set in Vercel for deployed
# environments; only needed locally if a feature needs an absolute URL.
NEXT_PUBLIC_ADMIN_BASE_URL=

# --- Firebase — client SDK (browser-safe) ---
# Config values from the Firebase console: Project settings -> General ->
# Your apps -> Web app -> SDK setup and configuration. These are NOT secrets
# (they identify the project to the browser, same as any public Firebase web
# config) but still ship blank here per the repo's names-only convention.
# Read lazily by src/lib/firebase/client.ts — never at import time.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase — Admin SDK (server-only service account) ---
# From a service account JSON key: Firebase console -> Project settings ->
# Service accounts -> Generate new private key. SECRET — never commit real
# values. FIREBASE_PRIVATE_KEY is stored with literal "\n" escapes in most env
# stores (Vercel included); src/lib/firebase/admin.ts un-escapes it before
# handing it to the SDK. Read lazily — never at import time (server-only.ts).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Email (CP2 auth — forthcoming) ---
# Not wired yet in this checkpoint (ICR-124 CP3). Reserved for the auth email
# flows (invite/reset) landing in CP2 of the auth ticket (ICR-125+). Mirrors
# apps/web's RESEND_API_KEY / FROM_EMAIL — see that app's .env.example.
RESEND_API_KEY=
FROM_EMAIL=
