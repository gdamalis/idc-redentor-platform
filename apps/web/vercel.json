{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/predica/regenerate-pdf/cron",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "src/app/api/predica/regenerate-pdf/cron/route.ts": {
      "maxDuration": 60
    }
  }
}
