{
  "extends": "@idcr/config/tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@public/*": ["./public/*"],
      "@src/*": ["./src/*"],
      "@lib/*": ["./lib/*"],
      "@icons/*": ["./public/assets/svg/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "trial-idcr"]
}
