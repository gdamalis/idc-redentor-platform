{
  "mcpServers": {
    "contentful": {
      "command": "npx",
      "args": ["-y", "@contentful/mcp-server"],
      "env": {
        "CONTENTFUL_MANAGEMENT_ACCESS_TOKEN": "${CONTENTFUL_MANAGEMENT_ACCESS_TOKEN}",
        "SPACE_ID": "${CONTENTFUL_SPACE_ID}",
        "ENVIRONMENT_ID": "agent-sandbox",
        "PROTECTED_ENVIRONMENTS": "master"
      }
    }
  }
}
